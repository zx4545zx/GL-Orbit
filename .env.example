DATABASE_URL=postgres://user:password@host.neon.tech/database?sslmode=require
AUTH_SECRET=your-secret-key-here
READONLY_DATABASE_URL=postgres://readonly_user:password@host.neon.tech/database?sslmode=require
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_API_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-Text-01

# Web Push VAPID keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Public VAPID key exposed to client
VITE_VAPID_PUBLIC_KEY=

# Cloudflare R2
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=gl-orbit-media
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
